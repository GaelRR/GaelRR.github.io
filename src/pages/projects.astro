---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
---

<BaseLayout title="Projects — Gael Rivera">
  <h1>Projects</h1>

  <ul class="project-list">
    {
      projects.map((project) => (
        <li class="project-list__item">
          <a class="project-list__link" href={`/projects/${project.slug}`}>
            <img
              class="project-list__image"
              src={project.image}
              alt=""
              width="120"
              height="120"
              loading="lazy"
            />
            <span class="project-list__text">
              <span class="project-list__name">{project.name}</span>
              <span class="project-list__tagline">{project.tagline}</span>
              <span class="project-list__summary">{project.summary}</span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
